# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local

# ── Runtime database ──────────────────────────────────────────────────────────
# db/ folder is auto-created by server.js on first run. Track the folder
# itself (.gitkeep) but never commit the database contents.
db/*.db
db/*.db-shm
db/*.db-wal

# Legacy db files if they exist in root (before reorganisation)
ici_chats.db
ici_chats.db-shm
ici_chats.db-wal

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Claude Code project settings (machine-specific) ───────────────────────────
.claude/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── GitHub Pages / Jekyll (legacy) ────────────────────────────────────────────
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
/vendor
Gemfile.lock
