# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local

# ── Runtime database ──────────────────────────────────────────────────────────
# db/ folder is auto-created by server.js on first run. Track the folder
# itself (.gitkeep) but never commit the database contents.
db/*.db
db/*.db-shm
db/*.db-wal

# Legacy db files if they exist in root (before reorganisation)
ici_chats.db
ici_chats.db-shm
ici_chats.db-wal

# ── ICI research workspace (large local-only assets) ──────────────────────────
# ~1.9 GB of source PDFs, bill texts, and CSV corpora that the Python RAG
# pipeline reads locally. Far too large for the site repo — kept on-machine
# only, never pushed. See ISSUES.md "Asset Inventory" / PIPELINEWORKFLOW.md.
ici_workspace/

# ── Python retrieval pipeline ─────────────────────────────────────────────────
# Heavy/derived pipeline artifacts stay local: parquet, sqlite, chroma index,
# eval + query logs. Code and small fixtures are tracked; out/ never is.
pipeline/out/
pipeline/.venv/
__pycache__/
*.pyc
.pytest_cache/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Claude Code project settings (machine-specific) ───────────────────────────
.claude/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── GitHub Pages / Jekyll (legacy) ────────────────────────────────────────────
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
/vendor
Gemfile.lock
